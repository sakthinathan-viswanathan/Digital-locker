# Create .gitignore file
echo "# Dependencies
node_modules/
package-lock.json
yarn.lock

# Environment variables
.env
.env.local
.env.*.local

# Build outputs
dist/
build/
*.log

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Firebase service account keys
*.json
!package.json

# Supabase keys (if any)
supabase-key-*.txt

# Temporary files
tmp/
temp/
uploads/
*.tmp" > .gitignore