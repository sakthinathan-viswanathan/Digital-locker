# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Firebase Admin SDK (Firestore only)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@digital-locker-e327c.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# Supabase (Storage only — the actual file bytes)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=sb_secret_y_v1****************************************  
SUPABASE_BUCKET=locker-files

# Comma-separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:5173,https://your-app.vercel.app

# Base URL used to build password-reset links (defaults to the first CLIENT_ORIGIN)
CLIENT_URL=http://localhost:5173

# SMTP (optional) — used to send "forgot password" emails.
# If left blank, the backend logs the reset link to the console instead,
# and (outside production) returns it in the API response for local testing.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Vaultly <no-reply@vaultly.app>"

# Max upload size
MAX_UPLOAD_MB=15